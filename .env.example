SECRET_KEY=vygeneruj-dlhy-nahodny-kluc
DEBUG=False
ALLOWED_HOSTS=pochop.sk,www.pochop.sk
CSRF_TRUSTED_ORIGINS=https://pochop.sk,https://www.pochop.sk

# AI runtime (Vercel AI Gateway only)
DEFAULT_MODEL=openai/gpt-5.2
VERCEL_AI_GATEWAY_API_KEY=tvoj-vercel-ai-gateway-api-kluc
VERCEL_AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1
VERCEL_AI_GATEWAY_DEFAULT_MODEL=openai/gpt-4o-mini
AI_FORCE_VERCEL_GATEWAY=True
AI_MAX_CALLS_DAILY=500
AI_MODEL_SWITCH_EAGER_USERS_REFRESH=False
AI_RESPONSE_CACHE_ENABLED=True
AI_RESPONSE_CACHE_TTL_SECONDS=86400

# Password reset e-mail
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=change-me
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=noreply@pochop.sk
MOMENT_REPORT_ADMIN_EMAILS=admin@pochop.sk
# Optional: real SMTP integration test
RUN_REAL_SMTP_TESTS=0
SMTP_TEST_RECIPIENT=test@example.com

# PII encryption (birth_place) - nastav vlastné heslo
PII_ENCRYPTION_PASSWORD=zmen-ma-na-silne-heslo

ADMIN_EMAIL=agilehardware@gmail.com
